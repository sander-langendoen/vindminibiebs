{
  "scripts": {
    "build:css": "sass style.scss assets/css/theme.css && sass editor.scss assets/css/editor.css",
    "watch:css": "sass --watch style.scss:assets/css/theme.css editor.scss:assets/css/editor.css",
    "build:js": "esbuild assets/js/custom.js --bundle --format=esm --outfile=assets/js/bundle.js",
    "watch:js": "esbuild assets/js/custom.js --bundle --format=esm --outfile=assets/js/bundle.js --watch",
    "build": "npm run build:css && npm run build:js",
    "start": "npm-run-all --parallel watch:css watch:js"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.77.0"
  }
}
